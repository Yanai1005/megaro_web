{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/_app/*", "/favicon.*", "/*.{png,jpg,svg,ico,css,js}"]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN",
    "X-XSS-Protection": "1; mode=block"
  },
  "mimeTypes": {
    ".json": "text/json",
    ".gz": "application/octet-stream"
  },
  "routes": [
    {
      "route": "/dict/*",
      "headers": {
        "Content-Type": "application/octet-stream",
        "Content-Encoding": "identity"
      }
    }
  ]
}
